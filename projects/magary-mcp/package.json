{
  "name": "magary-mcp",
  "version": "1.0.1",
  "description": "MCP Server for ng-magary library",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc scripts/generate-catalog.ts --target esnext --module nodenext --moduleResolution nodenext && node scripts/generate-catalog.js && tsc && copyfiles -f src/catalog.json build/",
    "start": "node build/index.js",
    "dev": "node build/index.js"
  },
  "bin": {
    "magary-mcp": "./build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "glob": "^10.3.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "copyfiles": "^2.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
